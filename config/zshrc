# Set the directory we want to store zinit and plugins
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

# Download Zinit, if it's not there yet
if [ ! -d "$ZINIT_HOME" ]; then
   mkdir -p "$(dirname $ZINIT_HOME)"
   git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

# Source/Load zinit (only once)
source "${ZINIT_HOME}/zinit.zsh"

# Starship prompt
eval "$(starship init zsh)"

# Skip compinit security checks (only run full check once per day)
autoload -Uz compinit
setopt EXTENDEDGLOB
local zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
if [[ -s "$zcompdump" && (! -s "${zcompdump}.zwc" || "$zcompdump" -nt "${zcompdump}.zwc") ]]; then
  zcompile "$zcompdump"
fi
if [[ -n $zcompdump(#qNmh-20) ]]; then
  compinit -C -d "$zcompdump"
else
  compinit -i -d "$zcompdump"
fi
unsetopt EXTENDEDGLOB

# Add in zsh plugins (aggressive turbo mode)
zinit wait lucid for \
    zdharma-continuum/fast-syntax-highlighting \
    zsh-users/zsh-completions

# Load autosuggestions with delay
zinit wait lucid atload"_zsh_autosuggest_start" for \
    zsh-users/zsh-autosuggestions

# Load fzf-tab immediately (needed for tab completion)
zinit light Aloxaf/fzf-tab

# Defer zsh-vi-mode (major performance hit)
zinit wait'1' lucid for \
    jeffreytse/zsh-vi-mode

# sources the alias file
source $HOME/dotfiles/config/aliases

# Source secrets if they exist
[ -f "$HOME/dotfiles/config/secrets/scripts/secret_aliases" ] && source "$HOME/dotfiles/config/secrets/scripts/secret_aliases"

# ~/.tmux/plugins
export PATH="$PATH:$HOME/.tmux/plugins/t-smart-tmux-session-manager/bin"

# zoxide init (lazy load)
eval "$(zoxide init zsh --no-cmd)"
alias cd='z'

# go (use default GOPATH to avoid slow command execution)
export GOPATH="${HOME}/go"
export PATH="$PATH:${GOPATH}/bin"

# nvm (lazy load - only load when needed)
export NVM_DIR="$HOME/.nvm"
nvm() {
  unset -f nvm
  [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
  nvm "$@"
}

# open nvim directly into telescope
function fuzzy_nvim_start {
    if [ "$#" -eq 0 ]; then
        kick +'Telescope find_files hidden=false layout_config={height=0.9}'
    elif [ -d "$1" ]; then
        kick +"Telescope find_files hidden=false layout_config={height=0.9} cwd=$1"
    else
        kick $@
    fi
}

# custom scripts
export PATH="$PATH:$HOME/dotfiles/config/scripts"

# fnm (keep this since you're using it instead of nvm)
export PATH="$PATH:$HOME/.fnm"
if command -v fnm &> /dev/null; then
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

# postgres
export PATH="$PATH:/opt/homebrew/opt/postgresql@15/bin"

# Python paths
export PATH="$HOME/.local/bin:/usr/local/opt/python/libexec/bin:$PATH"

# bob path (Neovim version manager)
if [ -f "$HOME/.local/share/bob/env/env.sh" ]; then
  . "$HOME/.local/share/bob/env/env.sh"
fi

export EDITOR="nvim"
export VISUAL="nvim"
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^x^e' edit-command-line

# opencode
if [ -d "$HOME/.opencode/bin" ]; then
  export PATH="$HOME/.opencode/bin:$PATH"
fi

# java (lazy load to avoid slow command execution)
if [[ -z "$JAVA_HOME" ]]; then
  export JAVA_HOME="$(/usr/libexec/java_home -v 21 2>/dev/null || echo '')"
fi

